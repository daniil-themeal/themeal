{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev: local server",
      "type": "npm",
      "script": "dev",
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "Local:\\s+http://127\\.0\\.0\\.1:5173/"
        }
      },
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      }
    }
  ]
}
