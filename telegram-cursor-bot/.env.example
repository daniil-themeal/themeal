# Telegram: create via @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC...

# Cursor: https://cursor.com/dashboard → Integrations → API Keys
CURSOR_API_KEY=crsr_...

# Comma-separated Telegram user IDs allowed to use the bot (empty = allow all)
ALLOWED_USER_IDS=

# Optional extra usernames (without @). Repo file allowed-users.json is merged in too.
ALLOWED_USERNAMES=

# Agent mode: local | cloud
# local  → меняет файлы в WORKSPACE на этом ПК (синхронно с Cursor IDE)
# cloud  → меняет GitHub в облаке Cursor; на ПК нужен git pull
AGENT_MODE=local

# --- local mode ---
# Path to the repo the agent should work in (absolute path recommended)
WORKSPACE=C:\Users\Bender\Desktop\Landing_20.05_TEST

# --- cloud mode ---
# GitHub repo URL for cloud agents
CLOUD_REPO_URL=https://github.com/daniil-themeal/themeal.git
CLOUD_REPO_REF=feature/next

# Cursor model
CURSOR_MODEL=composer-2.5

# Production URL (for status messages)
VERCEL_URL=https://landing-20-05-test.vercel.app

# true  → агент pushит в GitHub + бот дергает Vercel hook
# false → только локальный commit в cloud/local sandbox, без push
AUTO_PUSH=true

# Vercel deploy hook (optional, for production after push)
VERCEL_DEPLOY_HOOK=
